{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "env": {
    "browser": true,
    "es2022": true,
    "node": true
  },
  "ignorePatterns": [
    "node_modules/**",
    "dist/**",
    "coverage/**",
    "playwright-report/**",
    "test-results/**"
  ],
  "plugins": ["typescript", "react", "react-hooks", "jsx-a11y", "import"],
  "rules": {
    "no-console": "off"
  }
}
